<launch>
  <!-- Start only the hardware pieces needed by the interactive calibration script. -->
  <arg name="robot_name" default="sgr532"/>
  <include file="$(find sagittarius_moveit)/launch/demo_true.launch" />
  <node pkg="sagittarius_object_color_detector" type="sgr_ctrl.py" name="sgr_ctrl_node" output="screen" ns="$(arg robot_name)">
    <!-- Calibration should not move the arm just because this base launch starts. -->
    <param name="init_pose" value="false"/>
  </node>

  <arg name="video_dev" default="/dev/usb_cam" />
  <arg name="image_width" default="640" />
  <arg name="image_height" default="480" />
  <arg name="framerate" default="10" />
  <arg name="pixel_format" default="mjpeg" />
  <arg name="io_method" default="mmap" />
  <arg name="usb_cam_output" default="log" />
  <arg name="usb_cam_stderr_log" default="$(env HOME)/.ros/log/usb_cam_stderr.log" />

  <include file="$(find sagittarius_object_color_detector)/launch/usb_cam.launch">
    <arg name="video_dev" value="$(arg video_dev)"/>
    <arg name="image_width" value="$(arg image_width)"/>
    <arg name="image_height" value="$(arg image_height)"/>
    <arg name="framerate" value="$(arg framerate)"/>
    <arg name="pixel_format" value="$(arg pixel_format)"/>
    <arg name="io_method" value="$(arg io_method)"/>
    <arg name="output" value="$(arg usb_cam_output)"/>
    <arg name="stderr_log" value="$(arg usb_cam_stderr_log)"/>
  </include>
</launch>
